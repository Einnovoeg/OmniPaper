#!/bin/bash

GIT_LS_FILES_FLAGS=""
if [[ "$1" == "-g" ]]; then
  GIT_LS_FILES_FLAGS="--modified"
fi

# --- Main Logic ---

# Format all files (or only modified files if -g is passed)

# Use 'git ls-files' to get a list of tracked files. Restrict formatting to
# first-party code paths that this repository actively maintains; vendored
# upstream trees and generated assets are intentionally excluded to avoid
# meaningless churn in mirrored third-party code.
git ls-files --exclude-standard ${GIT_LS_FILES_FLAGS} \
    | grep -E '^(src|lib/(GfxRenderer|hal))/.*\.(c|cpp|h|hpp)$' \
    | grep -v -E '^lib/EpdFont/builtinFonts/' \
    | xargs -r clang-format -style=file -i
